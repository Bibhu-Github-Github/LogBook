import re
from collections import Counter
import openpyxl

# ── STOP WORDS: common/filler words to ignore when picking initials ────────────
STOP_WORDS = {
    'a', 'an', 'the', 'of', 'in', 'at', 'to', 'for', 'and', 'or', 'but',
    'is', 'are', 'was', 'were', 'be', 'been', 'by', 'on', 'with', 'as',
    'from', 'that', 'this', 'it', 'its', 'into', 'than', 'then',
    'per', 'very', 'high', 'low', 'amount', 'level', 'value',
    'over', 'under', 'above', 'below', 'across', 'within', 'number',
    'all', 'any', 'if', 'more', 'sub', 'rolling', 'three', 'month',
    'basis', 'cases', 'total'
}

# ── MUST INCLUDE WORDS: domain words that must never be skipped ────────────────
MUST_INCLUDE_WORDS = {
    'operational', 'risk', 'liquidity', 'capital', 'regulatory', 'conduct',
    'sanctions', 'compliance', 'credit', 'market', 'financial', 'insurance',
    'fcc', 'residual', 'sufficiency', 'losses', 'breaches', 'outcome',
    'processing', 'fencing', 'attributable', 'monthly', 'helios',
    'quality', 'sales', 'complaints', 'learning', 'mandatory', 'overdue',
    'penalties', 'fines', 'enforcement', 'people', 'personal', 'trimester',
    'employees', 'gmt', 'rc'
}


def clean_text(text):
    # Remove all special characters, keep only letters and spaces
    return re.sub(r'[^a-zA-Z\s]', '', str(text)).strip()


def get_unique_initials(metric_name, all_metrics_for_entity):
    # Clean the metric name first
    cleaned_name = clean_text(metric_name)
    words = cleaned_name.split()

    # Split words into must-include and optional groups
    must_have = [w for w in words if w.lower() in MUST_INCLUDE_WORDS]
    optional  = [w for w in words if w.lower() not in STOP_WORDS
                                  and w.lower() not in MUST_INCLUDE_WORDS]

    # Count word frequency across all metrics of same entity
    all_words_lower = []
    for m in all_metrics_for_entity:
        all_words_lower.extend(clean_text(m).lower().split())
    word_freq = Counter(all_words_lower)

    # Sort optional words by rarity — rarest word = most unique
    optional_sorted = sorted(optional, key=lambda w: word_freq[w.lower()])

    # Fill 3 slots: must-include words first, then rarest optional
    selected = must_have[:3]
    for w in optional_sorted:
        if len(selected) >= 3:
            break
        if w not in selected:
            selected.append(w)

    # Restore natural left-to-right word order
    selected_ordered = sorted(selected, key=lambda w: words.index(w))

    # Take first letter of each, pad with X if fewer than 3 words
    initials = ''.join(w[0].upper() for w in selected_ordered)
    return initials[:3].ljust(3, 'X')


def generate_metric_id(entity_code, metric_name, serial, all_metrics_for_entity):
    # entity_code is already cleaned 4-char code passed in
    initials_code = get_unique_initials(metric_name, all_metrics_for_entity)

    # Zero-pad serial to 3 digits, resets per entity
    serial_str = str(serial).zfill(3)

    # Always exactly 10 characters
    metric_id = f"{entity_code}{initials_code}{serial_str}"
    assert len(metric_id) == 10, f"ID length error: {metric_id}"
    return metric_id


def process_excel(input_file, output_file):
    # Load the existing workbook preserving all formatting
    wb = openpyxl.load_workbook(input_file)
    ws = wb.active

    # ── Find which column contains "Metric ID" in header row ──────────────────
    # This avoids hardcoding column number — works even if columns shift
    metric_id_col = None
    entity_col    = None
    metrics_col   = None

    for cell in ws[1]:
        if cell.value and 'metric id' in str(cell.value).lower():
            metric_id_col = cell.column
        if cell.value and str(cell.value).strip().lower() == 'entity':
            entity_col = cell.column
        if cell.value and str(cell.value).strip().lower() == 'metrics':
            metrics_col = cell.column

    print(f"Entity col: {entity_col}, Metrics col: {metrics_col}, Metric ID col: {metric_id_col}")

    if not all([metric_id_col, entity_col, metrics_col]):
        raise ValueError("Could not find required columns. Check header names: Entity, Metrics, Metric ID")

    # ── Read all data rows — skip header row 1 ────────────────────────────────
    all_rows = []
    for row in ws.iter_rows(min_row=2, values_only=True):
        if not any(row):
            continue
        all_rows.append(row)

    # ── Extract entity code from the INBB column (col B in your file) ─────────
    # Your entity column A has full name like "Insurance PINB_Risk..."
    # Column B has the actual short entity code "INBB" — use that instead
    # We find whichever column has short codes like INBB (col index for "L1 Risk" neighbour)
    # Based on your file: column B = short entity code (INBB)
    # So we use column index 1 (0-based) which is column B

    # ── Group metric names by entity code for uniqueness scoring ──────────────
    entity_metrics_map = {}
    for row in all_rows:
        # Column B (index 1) has the short entity code e.g. INBB
        raw_entity  = str(row[entity_col - 1]) if row[entity_col - 1] else ''
        entity_code = re.sub(r'[^a-zA-Z0-9]', '', raw_entity).upper()[:4]
        metric_name = str(row[metrics_col - 1]) if row[metrics_col - 1] else ''
        entity_metrics_map.setdefault(entity_code, []).append(metric_name)

    # ── Generate and write Metric ID directly into existing column ─────────────
    entity_serial_counter = {}  # serial resets per entity

    for i, row in enumerate(ws.iter_rows(min_row=2), start=2):
        # Skip empty rows
        if not any(cell.value for cell in row):
            continue

        # Get entity code from column B (short code like INBB)
        raw_entity  = str(ws.cell(i, entity_col).value or '')
        entity_code = re.sub(r'[^a-zA-Z0-9]', '', raw_entity).upper()[:4]

        # Get metric name
        metric_name = str(ws.cell(i, metrics_col).value or '')

        # Increment serial for this entity — resets to 001 for each new entity
        entity_serial_counter[entity_code] = entity_serial_counter.get(entity_code, 0) + 1
        serial = entity_serial_counter[entity_code]

        # Get all metrics for this entity
        all_metrics_for_entity = entity_metrics_map.get(entity_code, [])

        # Generate the Metric ID
        metric_id = generate_metric_id(entity_code, metric_name, serial, all_metrics_for_entity)

        # Write ONLY into the existing Metric ID column — no new columns created
        ws.cell(row=i, column=metric_id_col).value = metric_id

        print(f"Row {i}: {entity_code} | {metric_name[:40]:<40} | {metric_id}")

    # Save to output file — original file untouched
    wb.save(output_file)
    print(f"\n✅ Done! Saved to: {output_file}")


# ── Replace with your actual file paths ───────────────────────────────────────
INPUT_FILE  = "your_input_file.xlsx"
OUTPUT_FILE = "your_output_file.xlsx"
process_excel(INPUT_FILE, OUTPUT_FILE

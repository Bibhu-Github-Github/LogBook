import re
from collections import Counter

# Common/filler words to exclude (stop words)
STOP_WORDS = {
    'a', 'an', 'the', 'of', 'in', 'at', 'to', 'for', 'and', 'or', 'but',
    'is', 'are', 'was', 'were', 'be', 'been', 'by', 'on', 'with', 'as',
    'from', 'that', 'this', 'it', 'its', 'into', 'than', 'then', 'number',
    'total', 'per', 'very', 'high', 'low', 'percentage', 'amount', 'rate',
    'level', 'value', 'over', 'under', 'above', 'below', 'across', 'within'
}

def clean_text(text: str) -> str:
    """Remove all special characters and punctuation, keep only letters and spaces."""
    return re.sub(r'[^a-zA-Z\s]', '', text).strip()

def get_unique_initials(metric_name: str, all_metrics: list) -> str:
    cleaned_name = clean_text(metric_name)
    words = cleaned_name.split()

    # Remove stop words
    filtered = [w for w in words if w.lower() not in STOP_WORDS]

    # Score uniqueness across all metrics (after cleaning)
    all_words_lower = []
    for m in all_metrics:
        all_words_lower.extend(clean_text(m).lower().split())
    word_freq = Counter(all_words_lower)

    # Sort by rarest first
    filtered_sorted = sorted(filtered, key=lambda w: word_freq[w.lower()])

    # Take top 3, restore natural order
    top3 = filtered_sorted[:3]
    top3_ordered = sorted(top3, key=lambda w: words.index(w))

    initials = ''.join(w[0].upper() for w in top3_ordered)
    return initials[:3].ljust(3, 'X')


def generate_metric_id(entity: str, metric_name: str, serial: int, all_metrics: list) -> str:
    """Fixed-length Metric ID: 4 (Entity) + 3 (Initials) + 3 (Serial) = 10 chars"""
    # Clean entity too — remove any special chars, enforce 4 chars
    entity_code = re.sub(r'[^a-zA-Z0-9]', '', entity).upper().ljust(4)[:4]
    initials_code = get_unique_initials(metric_name, all_metrics)
    serial_str = str(serial).zfill(3)

    metric_id = f"{entity_code}{initials_code}{serial_str}"
    assert len(metric_id) == 10, f"ID length error: {metric_id}"
    return metric_id


def check_duplicates(ids: list) -> list:
    seen = {}
    dupes = []
    for mid, name in ids:
        if mid in seen:
            dupes.append((mid, seen[mid], name))
        seen[mid] = name
    return dupes


# --- Test with messy metric names containing special characters ---
metrics = [
    "Monthly Liquidity Ratio",
    "Capital Sufficiency",
    "Total Operational Risk Losses (USD)",
    "Percentage of Exits / Ring-Fencing Processing >45 Days",
    "# of Regulatory Bank Attributable Sanctions Breaches",
    "Very High & Residual FCC Risks in Helios (L3 risk)",
    "Conduct Risk Outcome",
]

entity = "INBB"

print(f"{'Metric ID':<15} {'Initials':<10} {'Cleaned Metric Name'}")
print("-" * 80)

generated = []
for i, metric in enumerate(metrics, start=1):
    metric_id = generate_metric_id(entity, metric, i, metrics)
    initials = get_unique_initials(metric, metrics)
    cleaned = clean_text(metric)
    print(f"{metric_id:<15} {initials:<10} {cleaned}")
    generated.append((metric_id, metric))

# Duplicate check
dupes = check_duplicates(generated)
if dupes:
    print("\n⚠️  DUPLICATE IDs DETECTED:")
    for mid, m1, m2 in dupes:
        print(f"  {mid} → '{m1}' and '{m2}'")
else:
    print("\n✅ All Metric IDs are unique!")
